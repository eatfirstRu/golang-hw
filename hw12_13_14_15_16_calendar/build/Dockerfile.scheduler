FROM golang:1.22-alpine as build

WORKDIR /go/src/

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG LDFLAGS
RUN CGO_ENABLED=0 go build -ldflags "$LDFLAGS" -o /opt/calendar/scheduler cmd/calendar_scheduler/*

FROM alpine:3.19

COPY --from=build /opt/calendar/scheduler /opt/calendar/scheduler
COPY ./configs/scheduler_docker.yaml /etc/calendar/config.yaml

CMD ["/opt/calendar/scheduler", "-config", "/etc/calendar/config.yaml"]
